# Server
DATABASE_URL=postgres://postgres:dev@localhost:5432/psst
SESSION_SECRET=change-me-to-a-32-char-random-string
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Reverse proxies allowed to set x-forwarded-for (comma-separated CIDRs).
# Leave empty to ignore the header and use the direct connection IP. Set this to
# your load balancer's range in production, otherwise clients can spoof their IP.
TRUSTED_PROXIES=

# Email (Resend) — leave RESEND_API_KEY/EMAIL_FROM unset to log emails to the console in dev
RESEND_API_KEY=
EMAIL_FROM=Psst <noreply@yourdomain.com>
APP_URL=http://localhost:5173

# File storage (MinIO in dev; swap endpoint/keys for R2 or S3 in prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=psst-files
STORAGE_REGION=us-east-1

# Turborepo remote cache (optional)
TURBO_TOKEN=
TURBO_TEAM=
